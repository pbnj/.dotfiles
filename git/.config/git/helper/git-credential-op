#!/usr/bin/env bash
# git-credential-op <1password_item_uuid> <action>

set -euo pipefail

ITEM_UUID=$1
ACTION=$2

# Git passes actions like 'get', 'store', or 'erase' via stdin.
# We only care about 'get'.
if [[ "$ACTION" != "get" ]]; then
  exit 0
fi

# 1Password requires the user to be authenticated.
# Ensure op is available.
if ! command -v op &>/dev/null; then
  echo "Error: 1Password CLI 'op' not found." >&2
  exit 1
fi

# Fetch credentials securely.
# Fetch username and token fields together in one command.
# op returns the requested fields separated by a comma (or other separator).
output=$(op item get "$ITEM_UUID" --fields username,token --reveal)

# Split ONLY on the first comma.
# ${output%%,*} takes everything up to the first comma.
# ${output#*,} takes everything after the first comma.
username="${output%%,*}"
password="${output#*,}"

echo "username=$username"
echo "password=$password"
