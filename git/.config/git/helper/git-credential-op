#!/usr/bin/env bash
# git-credential-op [--account <account>] <1password_item_uuid> <action>

set -euo pipefail

ACCOUNT=""
ITEM_UUID=""
ACTION=""

# Parse arguments. Git appends the action as the last argument.
while [[ $# -gt 0 ]]; do
  case "$1" in
  --account)
    ACCOUNT="$2"
    shift 2
    ;;
  get | store | erase)
    ACTION="$1"
    shift
    ;;
  *)
    ITEM_UUID="$1"
    shift
    ;;
  esac
done

# Git passes actions like 'get', 'store', or 'erase' via stdin.
# We only care about 'get'.
if [[ "$ACTION" != "get" ]]; then
  exit 0
fi

# 1Password requires the user to be authenticated.
# Ensure op is available.
if ! command -v op &>/dev/null; then
  echo "Error: 1Password CLI 'op' not found." >&2
  exit 1
fi

# Build op args. Optionally target a specific 1Password account.
op_args=(item get "$ITEM_UUID" --fields "username,token" --reveal)
if [[ -n "$ACCOUNT" ]]; then
  op_args+=(--account "$ACCOUNT")
fi

# Fetch credentials securely in one command.
# op returns the requested fields separated by a comma.
output=$(op "${op_args[@]}")

# Split ONLY on the first comma in case the token contains commas.
username="${output%%,*}"
password="${output#*,}"

echo "username=$username"
echo "password=$password"
