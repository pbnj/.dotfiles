#!/usr/bin/env -S uv run --script

# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "click",
#   "crawl4ai",
#   "ddgs",
#   "requests",
#   "rich",
#   "simple-term-menu",
# ]
# ///

"""
Interactive web search wrapper around the search-web skill.

When stdout is a TTY: shows a navigable menu with preview and opens results
in the browser on Enter.  When piped / non-interactive: passes JSON through
unchanged so it can be consumed by other tools.
"""

import asyncio
import json
import sys
import webbrowser
from typing import Optional

import click
import requests
from crawl4ai import AsyncWebCrawler, CrawlerRunConfig
from crawl4ai.async_configs import CacheMode
from ddgs import DDGS
from simple_term_menu import TerminalMenu

SEARXNG_DEFAULT_URL = "http://localhost:8888"


async def _fetch_contents(urls: list[str]) -> dict[str, str]:
    """Fetch page content for a list of URLs using crawl4ai."""
    config = CrawlerRunConfig(cache_mode=CacheMode.BYPASS)
    async with AsyncWebCrawler() as crawler:
        results = await crawler.arun_many(urls=urls, config=config)
    return {r.url: (r.markdown or "") if r.success else "" for r in results}


def _search_searxng(
    query: str, base_url: str, num: int, region: str, safesearch: str, page: int = 1
) -> list[dict]:
    safesearch_map = {"off": 0, "moderate": 1, "strict": 2}
    params = {
        "q": query,
        "format": "json",
        "language": region,
        "safesearch": safesearch_map.get(safesearch, 1),
        "pageno": page,
    }
    url = f"{base_url.rstrip('/')}/search"
    resp = requests.get(url, params=params, timeout=5)
    resp.raise_for_status()
    data = resp.json()
    return [
        {
            "title": r.get("title", ""),
            "href": r.get("url", ""),
            "body": r.get("content", ""),
        }
        for r in data.get("results", [])[:num]
    ]


def _search_ddgs(
    query: str, num: int, region: str, safesearch: str, page: int = 1
) -> list[dict]:
    return list(
        DDGS().text(
            query,
            region=region,
            safesearch=safesearch,
            max_results=num,
            offset=(page - 1) * num,
        )
    )


def _run_search(
    query: str,
    num: int,
    region: str,
    site: Optional[str],
    safesearch: str,
    searxng_url: Optional[str],
    fetch_content: bool,
    page: int = 1,
    quiet: bool = False,
) -> list[dict]:
    if site:
        query = f"site:{site} {query}"

    base_url = searxng_url or SEARXNG_DEFAULT_URL
    results: list[dict] = []

    try:
        results = _search_searxng(query, base_url, num, region, safesearch, page)
        if not quiet:
            click.echo("engine: SearXNG", err=True)
    except Exception as e:
        if not quiet:
            click.echo(f"SearXNG unavailable ({e}), falling back to DuckDuckGo...", err=True)

    if not results:
        try:
            results = _search_ddgs(query, num, region, safesearch, page)
            if not quiet:
                click.echo("engine: DuckDuckGo", err=True)
        except Exception as e:
            click.echo(f"Error during search: {e}", err=True)
            sys.exit(1)

    if fetch_content and results:
        if not quiet:
            click.echo("Fetching page content...", err=True)
        urls = [r["href"] for r in results if r.get("href")]
        content_map = asyncio.run(_fetch_contents(urls))
        for r in results:
            r["content"] = content_map.get(r.get("href", ""), "")

    return results


def _fetch_and_render(url: str) -> None:
    """Fetch URL via crawl4ai and render its markdown in the terminal with rich."""
    from crawl4ai import AsyncWebCrawler
    from rich.console import Console
    from rich.markdown import Markdown
    from rich.panel import Panel

    async def _crawl() -> str:
        async with AsyncWebCrawler() as crawler:
            result = await crawler.arun(url=url)
            return result.markdown or "*(no content)*"

    console = Console()
    with console.status(f"Fetching [bold]{url}[/bold]...", spinner="dots"):
        md_text = asyncio.run(_crawl())

    console.clear()
    console.print(Panel(url, style="bold cyan", expand=False))
    console.print(Markdown(md_text))
    console.input("\n[dim]Press Enter to return...[/dim]")


def _interactive(
    query: str,
    num: int,
    region: str,
    site: Optional[str],
    safesearch: str,
    searxng_url: Optional[str],
    fetch_content: bool,
) -> None:
    page = 1
    last_idx = 0

    while True:
        results = _run_search(
            query=query,
            num=num,
            region=region,
            site=site,
            safesearch=safesearch,
            searxng_url=searxng_url,
            fetch_content=fetch_content,
            page=page,
            quiet=True,
        )

        if not results:
            click.echo(f"No results on page {page}.", err=True)
            if page > 1:
                page -= 1
                last_idx = 0
                continue
            break

        entries = [
            f"{i + 1:>2}. {r.get('title') or '(no title)'}"
            for i, r in enumerate(results)
        ]

        def preview(entry: str) -> str:
            try:
                idx = int(entry.split(".")[0].strip()) - 1
                r = results[idx]
            except (ValueError, IndexError):
                return ""
            parts = []
            if r.get("title"):
                parts.append(r["title"])
            if r.get("href"):
                parts.append(r["href"])
            if r.get("body"):
                parts += ["", r["body"]]
            if r.get("content"):
                parts += ["", "--- full content ---", r["content"][:2000]]
            return "\n".join(parts)

        title = (
            f"j/k ↑/↓ navigate  •  Tab: mark  •  Enter: view content  •  o: open in browser  •  n: next page  •  p: prev page  •  q/Esc: quit"
            f"  [page {page}]"
        )
        menu = TerminalMenu(
            entries,
            title=title,
            preview_command=preview,
            preview_size=0.4,
            preview_title="Preview",
            cursor_index=min(last_idx, len(results) - 1),
            clear_screen=True,
            accept_keys=("enter", "o", "n", "p"),
            multi_select=True,
            multi_select_select_on_accept=True,
            show_multi_select_hint=False,
        )
        idx = menu.show()
        key = menu.chosen_accept_key

        if idx is None:
            break
        elif key == "n":
            page += 1
            last_idx = 0
        elif key == "p":
            if page > 1:
                page -= 1
            last_idx = 0
        elif key == "o":
            # o — open all selected results in browser
            valid = [i for i in idx if i < len(results)]
            if valid:
                last_idx = valid[0]
                for i in valid:
                    url = results[i].get("href", "")
                    if url:
                        webbrowser.open(url)
        else:
            # Enter — fetch and render content as markdown
            valid = [i for i in idx if i < len(results)]
            if valid:
                last_idx = valid[0]
                for i in valid:
                    url = results[i].get("href", "")
                    if url:
                        _fetch_and_render(url)


@click.command(context_settings={"ignore_unknown_options": True})
@click.argument("keywords", nargs=-1, required=True)
@click.option("-n", "--num", type=int, default=10, help="Number of results (1-50)")
@click.option("-r", "--region", default="wt-wt", help="Region (e.g. us-en, wt-wt)")
@click.option("-w", "--site", default=None, help="Restrict to domain (e.g. github.com)")
@click.option(
    "--safesearch",
    type=click.Choice(["off", "moderate", "strict"]),
    default="moderate",
    help="Safe search level",
)
@click.option("--unsafe", is_flag=True, default=False, help="Alias for --safesearch off")
@click.option("--searxng-url", default=None, envvar="SEARXNG_URL", help="Override SearXNG base URL")
@click.option("--fetch", "fetch_content", is_flag=True, default=False, help="Fetch full page content via crawl4ai")
# ddgr-compatible flags accepted but ignored
@click.option("--np", "--noprompt", "noprompt", is_flag=True, hidden=True)
@click.option("-j", "--ducky", is_flag=True, hidden=True)
@click.option("-x", "--expand", is_flag=True, hidden=True)
@click.option("-C", "--nocolor", is_flag=True, hidden=True)
@click.option("--rev", "--reverse", "reverse", is_flag=True, hidden=True)
def main(
    keywords: tuple[str, ...],
    num: int,
    region: str,
    site: Optional[str],
    safesearch: str,
    unsafe: bool,
    searxng_url: Optional[str],
    fetch_content: bool,
    **_ignored,
) -> None:
    """Search the web. Interactive TUI when run in a terminal; JSON output when piped."""
    if unsafe:
        safesearch = "off"

    query = " ".join(keywords)

    if sys.stdout.isatty():
        _interactive(
            query=query,
            num=num,
            region=region,
            site=site,
            safesearch=safesearch,
            searxng_url=searxng_url,
            fetch_content=fetch_content,
        )
    else:
        results = _run_search(
            query=query,
            num=num,
            region=region,
            site=site,
            safesearch=safesearch,
            searxng_url=searxng_url,
            fetch_content=fetch_content,
        )
        if not results:
            click.echo(json.dumps([]))
            return
        click.echo(json.dumps(results, indent=2))


if __name__ == "__main__":
    main()
