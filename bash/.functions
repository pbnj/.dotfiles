#!/usr/bin/env bash

dateiso() {
        date +"%Y%m%dT%H%M%S"
}

brew() {
        arch -arm64 brew "$@"
}

paws() {
        AWS_CONFIG_FILE="$(mktemp)"
        export AWS_CONFIG_FILE
        op read "op://Employee/aws/config" >"${AWS_CONFIG_FILE}"
        command aws "$@"
        unset AWS_CONFIG_FILE
        rm -f "$AWS_CONFIG_FILE"
}
complete -C 'aws_completer' paws # for shell tab-completion


pkubectl() {
        AWS_CONFIG_FILE="$(mktemp)"
        export AWS_CONFIG_FILE
        op read "op://Employee/aws/config" >"${AWS_CONFIG_FILE}"
        command kubectl "$@"
        unset AWS_CONFIG_FILE
        rm -f "$AWS_CONFIG_FILE"
}
complete -o default -F __start_kubectl pkubectl # for shell tab-completion

llm() {
        llama-server \
                --models-max 1 \
                --no-mmproj \
                -ngl 999 \
                -fa on \
                --cache-type-k q8_0 \
                --cache-type-v q8_0 \
                --parallel 1 \
                --jinja \
                --chat-template-kwargs '{"preserve_thinking": true}'
}

__git_branch() {
  git branch --show-current 2>/dev/null | sed 's/^/ (/' | sed 's/$/)/'
}
