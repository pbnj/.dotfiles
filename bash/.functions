#!/usr/bin/env bash

dateiso() {
        date +"%Y%m%dT%H%M%S"
}

brew() {
        arch -arm64 brew $@
}

paws() {
        TMP_DIR="$(mktemp -d)"
        AWS_CONFIG_FILE="${TMP_DIR}/config"
        op read -o "${AWS_CONFIG_FILE}" "op://Employee/aws/config" &>/dev/null
        AWS_CONFIG_FILE="${TMP_DIR}/config" command aws $@
        rm -rf "${TMP_DIR}"
}
complete -C 'aws_completer' paws # for shell tab-completion

__git_branch() {
  git branch --show-current 2>/dev/null | sed 's/^/ (/' | sed 's/$/)/'
}
